# ─── Required ──────────────────────────────────────────────────────────

# JWT secret key — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production

# Google Custom Search credentials (for web search feature)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ─── LLM Provider ──────────────────────────────────────────────────────
# If OPENAI_API_KEY is set, the app uses an OpenAI-compatible API (Groq, OpenAI, etc.)
# If OPENAI_API_KEY is empty, the app uses the local llama-server.

# Get a free Groq key at https://console.groq.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.1-8b-instant

# For local llama-server (used only if OPENAI_API_KEY is empty):
LLAMA_SERVER_URL=http://127.0.0.1:8081/v1/chat/completions

# ─── Backend ───────────────────────────────────────────────────────────

DATABASE_URL=sqlite+aiosqlite:///./sidai.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_EXPIRE_HOURS=72
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60
LOG_LEVEL=INFO

# ─── Frontend ──────────────────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://127.0.0.1:8888
