# ═══════════════════════════════════════════════════════════════════════
# SID.AI — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env (local dev) or set these vars in your
# hosting dashboard (Render, Vercel, etc.).
# ═══════════════════════════════════════════════════════════════════════

# ─── Required ──────────────────────────────────────────────────────────

# JWT secret key — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Render will auto-generate this if you use the Blueprint (render.yaml)
JWT_SECRET_KEY=change-me-in-production

# Google Custom Search credentials (for web search feature — optional)
# Free tier: https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Google OAuth Client ID (for Sign in with Google)
# Get it from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# ─── LLM Provider ──────────────────────────────────────────────────────
# If OPENAI_API_KEY is SET → uses OpenAI-compatible API (Groq, OpenAI, etc.)
# If OPENAI_API_KEY is EMPTY → uses local llama-server (GGUF model)

# >>> Get a FREE Groq API key: https://console.groq.com <<<
# Groq gives 30 tokens/min free with llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.1-8b-instant

# For local llama-server (used only if OPENAI_API_KEY is empty):
LLAMA_SERVER_URL=http://127.0.0.1:8081/v1/chat/completions

# ─── Backend ───────────────────────────────────────────────────────────
# Render: use sqlite+aiosqlite:////tmp/sidai.db (uses ephemeral /tmp)
DATABASE_URL=sqlite+aiosqlite:///./sidai.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_EXPIRE_HOURS=72
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60
LOG_LEVEL=INFO

# ─── Frontend ──────────────────────────────────────────────────────────
# In production, set this to your backend URL (e.g. https://sidai-backend.onrender.com)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8888
